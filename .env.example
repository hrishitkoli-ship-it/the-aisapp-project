# Copy this to .env for local development (never commit the real .env file).
# On Vercel: set these directly in Project Settings -> Environment Variables.
# NEVER paste real values into chat with an AI assistant -- if a credential
# ever does end up in a chat, rotate it immediately from the Turso dashboard.

# Your Turso database's libsql:// URL. Find it via `turso db show <name>`
# or the Turso dashboard.
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io

# Auth token for the database above. Generate via `turso db tokens create <name>`
# or the dashboard. This token grants full read/write access to your data --
# treat it like a password.
TURSO_AUTH_TOKEN=your-token-here

# Optional, local dev only. Defaults to 7077 if unset.
PORT=7077

# Required only if you use the GitHub integration (#13, "Connect a repo
# per project"). Encrypts the GitHub PAT at rest before it's stored --
# any random string works, e.g. `openssl rand -base64 32`. Without
# this set, connecting a GitHub repo returns a clear 503 rather than
# silently storing the token in plaintext.
AISAPP_SECRET_KEY=your-random-string-here
